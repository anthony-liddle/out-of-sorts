{
  "name": "out-of-sorts",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A daily word game about attrition. Engine and solver.",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:fdroid": "vite build --mode fdroid",
    "check:flavour": "pnpm run build:fdroid && tsx scripts/check-flavour.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "bake": "tsx scripts/bake.ts",
    "verify:sweep": "tsx scripts/verify-sweep.ts",
    "bench": "tsx scripts/bench.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@vercel/analytics": "^1.5.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.30.0",
    "@types/node": "^22.15.0",
    "eslint": "^9.30.0",
    "eslint-config-prettier": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "prettier": "^3.6.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.35.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
